# GSEA-Based Meta-Summary Analysis
# Creates Excel outputs from GSEA results in .rds files

library(tidyverse)
library(openxlsx)

# Function to extract and process GSEA results
extract_gsea_results <- function(all_results, nes_cutoff = 1.5, pval_cutoff = 0.05) {
    
    cat("=== Extracting GSEA Results ===\n")
    cat("Processing", length(all_results), "cell types...\n")
    
    # Initialize storage for different GSEA types
    gsea_summary <- tibble()
    
    # Process each cell type
    for (cell_type in names(all_results)) {
        result <- all_results[[cell_type]]
        
        # Skip if error
        if ("error" %in% names(result)) {
            cat("Skipping", cell_type, "- analysis error\n")
            next
        }
        
        # Get GSEA results - CORRECTED: look for 'gsea' instead of 'gsea_results'
        gsea_results <- result$gsea
        if (is.null(gsea_results) || length(gsea_results) == 0) {
            cat("No GSEA results found for", cell_type, "\n")
            next
        }
        
        # Process each GSEA type (GSEA_GO_BP, GSEA_KEGG, GSEA_Reactome)
        for (gsea_type in names(gsea_results)) {
            gsea_data <- gsea_results[[gsea_type]]
            
            if (is.null(gsea_data) || !"result" %in% slotNames(gsea_data)) next
            
            gsea_df <- gsea_data@result
            if (nrow(gsea_df) == 0) next
            
            # Filter by significance and effect size
            significant_gsea <- gsea_df %>%
                filter(
                    p.adjust < pval_cutoff,
                    abs(NES) > nes_cutoff
                ) %>%
                mutate(
                    CellType = cell_type,
                    GSEA_Type = gsea_type,
                    Direction = ifelse(NES > 0, "Upregulated", "Downregulated"),
                    AbsNES = abs(NES)
                ) %>%
                dplyr::select(
                    CellType,
                    GSEA_Type,
                    Direction,
                    ID,
                    Description,
                    setSize,
                    NES,
                    AbsNES,
                    pvalue,
                    p.adjust,
                    qvalue,
                    core_enrichment
                )
            
            if (nrow(significant_gsea) > 0) {
                gsea_summary <- bind_rows(gsea_summary, significant_gsea)
            }
        }
    }
    
    cat("Total significant GSEA results:", nrow(gsea_summary), "\n")
    return(gsea_summary)
}

# Function to create theme-based groupings for GSEA results
create_gsea_theme_mapping <- function(gsea_summary) {
    
    cat("Creating theme-based groupings...\n")
    
    # Define theme keywords for GSEA pathway descriptions
    theme_keywords <- list(
        "Vascular_Angiogenesis" = c("angiogenesis", "blood vessel", "vasculature", "endothelial", "vascular development"),
        "ECM_Collagen" = c("collagen", "extracellular matrix", "basement membrane", "matrix organization", "ECM"),
        "Cell_Junction_Barrier" = c("tight junction", "cell junction", "adherens junction", "barrier", "cell adhesion"),
        "Immune_Inflammation" = c("immune", "inflammatory", "cytokine", "chemokine", "innate immune", "adaptive immune"),
        "Cell_Migration_Motility" = c("cell migration", "cell motility", "chemotaxis", "locomotion", "movement"),
        "Cell_Cycle_Proliferation" = c("cell cycle", "mitotic", "DNA replication", "cell division", "proliferation"),
        "Metabolic_Energy" = c("metabolic", "metabolism", "glycolysis", "oxidative phosphorylation", "energy", "glucose"),
        "Neural_Synaptic" = c("synaptic", "neurotransmitter", "neuronal", "axon", "dendrite", "neural"),
        "Apoptosis_Death" = c("apoptosis", "cell death", "programmed cell death", "necrosis"),
        "Signaling_Pathways" = c("signaling", "signal transduction", "pathway", "cascade", "MAPK", "PI3K", "Wnt"),
        "Stress_Response" = c("stress response", "oxidative stress", "DNA damage", "heat shock", "unfolded protein"),
        "Development_Differentiation" = c("development", "differentiation", "morphogenesis", "organogenesis", "stem cell")
    )
    
    # Add theme classification to GSEA results
    gsea_with_themes <- gsea_summary %>%
        rowwise() %>%
        mutate(
            Theme = {
                desc_lower <- tolower(Description)
                
                # Find matching themes
                matches <- character()
                for (theme_name in names(theme_keywords)) {
                    keywords <- theme_keywords[[theme_name]]
                    if (any(sapply(keywords, function(kw) grepl(kw, desc_lower, fixed = TRUE)))) {
                        matches <- c(matches, theme_name)
                    }
                }
                
                # Return first match or "Other"
                if (length(matches) > 0) {
                    matches[1]
                } else {
                    "Other"
                }
            }
        ) %>%
        ungroup()
    
    return(gsea_with_themes)
}

# Function to create cell-type focused summary
create_celltype_gsea_summary <- function(gsea_with_themes) {
    
    # Summary by cell type and theme
    celltype_summary <- gsea_with_themes %>%
        group_by(CellType, Theme, Direction, GSEA_Type) %>%
        summarise(
            Count = n(),
            Max_AbsNES = max(AbsNES),
            Min_Padj = min(p.adjust),
            Top_Pathway = Description[which.max(AbsNES)],
            .groups = "drop"
        ) %>%
        arrange(CellType, desc(Max_AbsNES))
    
    # Detailed results by cell type
    celltype_detailed <- gsea_with_themes %>%
        arrange(CellType, desc(AbsNES)) %>%
        dplyr::select(CellType, Theme, GSEA_Type, Direction, Description, 
               NES, p.adjust, setSize, core_enrichment)
    
    return(list(
        summary = celltype_summary,
        detailed = celltype_detailed
    ))
}

# Function to create theme-focused summary
create_theme_gsea_summary <- function(gsea_with_themes) {
    
    # Summary by theme across cell types
    theme_summary <- gsea_with_themes %>%
        group_by(Theme, Direction, GSEA_Type, CellType) %>%
        summarise(
            Count = n(),
            Max_AbsNES = max(AbsNES),
            Min_Padj = min(p.adjust),
            Top_Pathway = Description[which.max(AbsNES)],
            .groups = "drop"
        ) %>%
        arrange(Theme, desc(Max_AbsNES))
    
    # Theme overview across all cell types
    theme_overview <- gsea_with_themes %>%
        group_by(Theme, Direction) %>%
        summarise(
            Total_Pathways = n(),
            Cell_Types_Affected = n_distinct(CellType),
            Mean_AbsNES = mean(AbsNES),
            Cell_Types = paste(unique(CellType), collapse = ", "),
            .groups = "drop"
        ) %>%
        arrange(desc(Mean_AbsNES))
    
    return(list(
        summary = theme_summary,
        overview = theme_overview
    ))
}

# Function to create top pathways summary
create_top_pathways_summary <- function(gsea_with_themes, top_n = 20) {
    
    # Top pathways by NES across all cell types
    top_pathways <- gsea_with_themes %>%
        arrange(desc(AbsNES)) %>%
        head(top_n) %>%
        dplyr::select(CellType, Theme, GSEA_Type, Direction, Description, 
               NES, p.adjust, setSize, core_enrichment)
    
    # Most frequently enriched pathways
    frequent_pathways <- gsea_with_themes %>%
        group_by(Description, Theme, Direction) %>%
        summarise(
            Cell_Type_Count = n_distinct(CellType),
            Cell_Types = paste(unique(CellType), collapse = ", "),
            Mean_AbsNES = mean(AbsNES),
            Min_Padj = min(p.adjust),
            .groups = "drop"
        ) %>%
        filter(Cell_Type_Count > 1) %>%  # Only pathways in multiple cell types
        arrange(desc(Cell_Type_Count), desc(Mean_AbsNES))
    
    return(list(
        top_by_nes = top_pathways,
        frequent = frequent_pathways
    ))
}

# Main function to run GSEA-based analysis
run_gsea_meta_analysis <- function() {
    
    cat("=== GSEA META-ANALYSIS ===\n\n")
    
    # Updated path
    results_dir <- "/Users/jpmcginnis1/Desktop/Sequencing info and data/Ex vivo paper data/Diff exp CSVs/Near normal cell types"
    
    cat("Looking for RDS files in:", results_dir, "\n")
    
    # Find all RDS files with _d14_vs_d0_results pattern
    rds_files <- list.files(results_dir, pattern = "_d14_vs_d0_results\\.rds$", full.names = TRUE)
    
    if (length(rds_files) == 0) {
        stop("No RDS results files found.")
    }
    
    cat("Found", length(rds_files), "RDS files\n")
    
    # Load all results
    all_results <- list()
    for (rds_file in rds_files) {
        basename_file <- basename(rds_file)
        cell_type <- gsub("_d14_vs_d0_results\\.rds$", "", basename_file)
        
        tryCatch({
            result <- readRDS(rds_file)
            all_results[[cell_type]] <- result
        }, error = function(e) {
            cat("Error loading", cell_type, ":", e$message, "\n")
        })
    }
    
    if (length(all_results) == 0) {
        stop("No results could be loaded successfully")
    }
    
    cat("Successfully loaded", length(all_results), "cell types\n")
    
    # Extract GSEA results
    gsea_summary <- extract_gsea_results(all_results)
    
    if (nrow(gsea_summary) == 0) {
        stop("No significant GSEA results found across all cell types")
    }
    
    # Add theme classifications
    gsea_with_themes <- create_gsea_theme_mapping(gsea_summary)
    
    # Create different summary views
    celltype_summaries <- create_celltype_gsea_summary(gsea_with_themes)
    theme_summaries <- create_theme_gsea_summary(gsea_with_themes)
    pathway_summaries <- create_top_pathways_summary(gsea_with_themes)
    
    # Create Excel workbook
    timestamp <- format(Sys.time(), "%Y%m%d_%H%M")
    excel_file <- paste0("GSEA_Meta_Analysis_", timestamp, ".xlsx")
    
    cat("Creating Excel file:", excel_file, "\n")
    
    wb <- createWorkbook()
    
    # Sheet 1: Cell Type Summary
    addWorksheet(wb, "CellType_Summary")
    writeData(wb, "CellType_Summary", celltype_summaries$summary)
    
    # Sheet 2: Cell Type Detailed
    addWorksheet(wb, "CellType_Detailed")
    writeData(wb, "CellType_Detailed", celltype_summaries$detailed)
    
    # Sheet 3: Theme Summary
    addWorksheet(wb, "Theme_Summary")
    writeData(wb, "Theme_Summary", theme_summaries$summary)
    
    # Sheet 4: Theme Overview
    addWorksheet(wb, "Theme_Overview")
    writeData(wb, "Theme_Overview", theme_summaries$overview)
    
    # Sheet 5: Top Pathways
    addWorksheet(wb, "Top_Pathways")
    writeData(wb, "Top_Pathways", pathway_summaries$top_by_nes)
    
    # Sheet 6: Frequent Pathways
    addWorksheet(wb, "Frequent_Pathways")
    writeData(wb, "Frequent_Pathways", pathway_summaries$frequent)
    
    # Sheet 7: Raw GSEA Data
    addWorksheet(wb, "Raw_GSEA_Data")
    writeData(wb, "Raw_GSEA_Data", gsea_with_themes)
    
    # Save Excel file
    saveWorkbook(wb, excel_file, overwrite = TRUE)
    
    cat("✓ Excel file created:", excel_file, "\n")
    
    # Print summary
    cat("\n=== ANALYSIS SUMMARY ===\n")
    cat("Total GSEA pathways:", nrow(gsea_with_themes), "\n")
    cat("Cell types:", length(unique(gsea_with_themes$CellType)), "\n")
    cat("Themes:", length(unique(gsea_with_themes$Theme)), "\n")
    cat("GSEA types:", paste(unique(gsea_with_themes$GSEA_Type), collapse = ", "), "\n")
    
    # Show top themes
    cat("\nTop themes by pathway count:\n")
    theme_counts <- gsea_with_themes %>%
        count(Theme, sort = TRUE) %>%
        head(8)
    
    for (i in 1:nrow(theme_counts)) {
        cat(sprintf("  %s: %d pathways\n", theme_counts$Theme[i], theme_counts$n[i]))
    }
    
    return(list(
        gsea_data = gsea_with_themes,
        celltype_summaries = celltype_summaries,
        theme_summaries = theme_summaries,
        pathway_summaries = pathway_summaries,
        excel_file = excel_file
    ))
}

